    <div class="hero-badge">
      <span class="badge-dot"></span>
      <span>Disponibles para nuevos proyectos</span>
    </div>
    <h1>
      <span class="line1">Apps que</span>
      <span class="line2">resuelven.</span>
      <span class="line3">Tiempo</span>
      <span class="line3">que importa</span>
    </h1>
    <p class="hero-sub">
      Construimos aplicaciones móviles con <strong>Flutter</strong> que resisten el mundo real. Sin shortcuts. Sin deuda técnica acumulada. Sin excusas.
    </p>
    <div class="hero-actions">
      <a href="mailto:enxod3rz@gmail.com" class="btn-primary">Iniciar proyecto →</a>
      <a href="#proyectos" class="btn-ghost">Ver trabajos</a>
    </div>
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-num">60<span style="color:var(--accent);font-size:20px">fps</span></span>
        <span class="stat-label">Siempre</span>
      </div>
      <div class="stat">
        <span class="stat-num">&lt;24<span style="color:var(--muted);font-size:20px">h</span></span>
        <span class="stat-label">Respuesta garantizada</span>
      </div>
      <div class="stat">
        <span class="stat-num">0</span>
        <span class="stat-label">Bugs en producción*</span>
      </div>
    </div>
  </div>

  <div class="terminal">
    <div class="term-header">
      <div class="term-dot td-r"></div>
      <div class="term-dot td-y"></div>
      <div class="term-dot td-g"></div>
      <span style="font-family:var(--mono);font-size:12px;color:var(--muted);margin-left:8px">enxod3rz.config.ts</span>
    </div>
    <div class="term-body">
      <div class="t-comment">// Nuestra forma de trabajar</div>
      <br>
      <span class="t-key">const</span> studio = <br>
      &nbsp;&nbsp;<span class="t-key">stack:</span> [<span class="t-str">"Flutter"</span>, <span class="t-str">"React"</span>],<br>
      &nbsp;&nbsp;<span class="t-key">backend:</span> [<span class="t-str">"NestJS"</span>, <span class="t-str">"Firebase"</span>],<br>
      &nbsp;&nbsp;<span class="t-key">filosofia:</span> <span class="t-str">"clean code"</span>,<br>
      &nbsp;&nbsp;<span class="t-key">cobertura:</span> <span class="t-val">100</span>,<span class="t-comment"> // tests</span><br>
      &nbsp;&nbsp;<span class="t-key">compromisos:</span> <span class="t-val">true</span>,<br>
      &nbsp;&nbsp;<span class="t-key">excusas:</span> <span class="t-val">false</span>,<br>
      <br><br>
      <span class="t-comment">// Comenza tu idea...</span> <span class="t-cursor"></span>
    </div>
  </div>
</section>

<div class="divider"></div>

<section id="filosofia" class="section">
  <div class="section-tag">// nuestro stack</div>
  <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:24px">
    <div>
      <h2 class="section-title">¿Por qué<br>elegirnos?</h2>
