---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Enxod3rz | Creadores de Apps" description="Expertos en Flutter y soluciones escalables.">

<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap');

  *{margin:0;padding:0;box-sizing:border-box}
  :root{
    --bg:#0a0a0f;
    --surface:#12121a;
    --surface2:#1a1a26;
    --border:#ffffff14;
    --border2:#ffffff22;
    --text:#f0f0f8;
    --muted:#8888a8;
    --accent:#4f7fff;
    --accent2:#7c4fff;
    --green:#22c98a;
    --font:'Space Grotesk',sans-serif;
    --mono:'JetBrains Mono',monospace;
  }
  body{background:var(--bg);color:var(--text);font-family:var(--font);overflow-x:hidden}

  .noise{position:fixed;inset:0;pointer-events:none;z-index:0;opacity:.04;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E")}

  .glow-orb{position:fixed;border-radius:50%;pointer-events:none;z-index:0;filter:blur(80px)}
  .orb1{width:600px;height:600px;background:radial-gradient(circle,#4f7fff18,transparent);top:-100px;left:-100px}
  .orb2{width:500px;height:500px;background:radial-gradient(circle,#7c4fff12,transparent);bottom:0;right:-100px}

  nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:20px 40px;display:flex;align-items:center;justify-content:space-between;backdrop-filter:blur(20px);background:#0a0a0f88;border-bottom:0.5px solid var(--border)}
  .logo{font-family:var(--mono);font-size:18px;font-weight:600;color:var(--text);letter-spacing:-0.5px;text-decoration:none}
  .logo span{color:var(--accent)}
  .nav-links{display:flex;gap:32px;list-style:none}
  .nav-links a{color:var(--muted);text-decoration:none;font-size:14px;transition:color .2s}
  .nav-links a:hover{color:var(--text)}
  .nav-cta{background:var(--accent);color:#fff;font-size:13px;font-weight:600;padding:10px 22px;border-radius:10px;text-decoration:none;transition:all .2s;font-family:var(--font)}
  .nav-cta:hover{background:#3d6ee8;transform:translateY(-1px)}

  .hero{position:relative;z-index:1;min-height:100vh;display:flex;align-items:center;padding:120px 40px 80px}
  .hero-inner{max-width:900px;margin:0 auto;width:100%}
  .hero-badge{display:inline-flex;align-items:center;gap:8px;background:var(--surface);border:0.5px solid var(--border2);border-radius:100px;padding:8px 16px;font-family:var(--mono);font-size:12px;color:var(--muted);margin-bottom:40px}
  .badge-dot{width:7px;height:7px;border-radius:50%;background:var(--green);box-shadow:0 0 8px var(--green);animation:pulse 2s infinite}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}

  .hero h1{font-size:clamp(48px,7vw,88px);font-weight:700;line-height:1;letter-spacing:-3px;margin-bottom:32px}
  .hero h1 .line1{display:block;color:var(--text)}
  .hero h1 .line2{display:block;background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
  .hero h1 .line3{display:block;color:var(--muted);font-weight:400}

  .hero-sub{font-size:18px;color:var(--muted);line-height:1.7;max-width:560px;margin-bottom:48px}
  .hero-sub strong{color:var(--text);font-weight:500}

  .hero-actions{display:flex;gap:16px;flex-wrap:wrap;align-items:center;margin-bottom:80px}
  .btn-primary{background:var(--accent);color:#fff;font-size:15px;font-weight:600;padding:16px 32px;border-radius:12px;text-decoration:none;transition:all .2s;font-family:var(--font)}
  .btn-primary:hover{background:#3d6ee8;transform:translateY(-2px);box-shadow:0 8px 30px #4f7fff33}
  .btn-ghost{color:var(--text);font-size:15px;font-weight:500;padding:16px 32px;border-radius:12px;text-decoration:none;border:0.5px solid var(--border2);transition:all .2s;font-family:var(--font);background:var(--surface)}
  .btn-ghost:hover{border-color:var(--accent);color:var(--accent)}

  .hero-stats{display:flex;gap:48px}
  .stat{display:flex;flex-direction:column;gap:4px}
  .stat-num{font-size:32px;font-weight:700;color:var(--text)}
  .stat-label{font-size:13px;color:var(--muted)}

  .terminal{position:absolute;right:40px;top:50%;transform:translateY(-50%);width:380px;background:var(--surface);border:0.5px solid var(--border2);border-radius:16px;overflow:hidden;display:none}
  @media(min-width:1200px){.terminal{display:block}}
  .term-header{display:flex;align-items:center;gap:8px;padding:14px 16px;border-bottom:0.5px solid var(--border)}
  .term-dot{width:12px;height:12px;border-radius:50%}
  .td-r{background:#ff5f56}.td-y{background:#ffbd2e}.td-g{background:#27c93f}
  .term-body{padding:20px;font-family:var(--mono);font-size:13px;line-height:1.8;min-height:200px}
  .t-comment{color:#556}
  .t-key{color:var(--accent2)}
  .t-val{color:var(--green)}
  .t-str{color:#ff9f6e}
  .t-cursor{display:inline-block;width:8px;height:14px;background:var(--accent);animation:blink .8s infinite;vertical-align:middle}
  @keyframes blink{0%,100%{opacity:1}50%{opacity:0}}

  .divider{height:0.5px;background:var(--border);margin:0 40px}

  .section{position:relative;z-index:1;padding:100px 40px;max-width:1100px;margin:0 auto}
  .section-tag{font-family:var(--mono);font-size:12px;color:var(--accent);letter-spacing:2px;text-transform:uppercase;margin-bottom:16px}
  .section-title{font-size:clamp(32px,5vw,52px);font-weight:700;letter-spacing:-2px;color:var(--text);margin-bottom:16px}
  .section-sub{font-size:17px;color:var(--muted);max-width:500px;line-height:1.6}

  .stack-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px;margin-top:64px}
  .stack-card{background:var(--surface);border:0.5px solid var(--border);border-radius:16px;padding:28px;transition:all .3s;cursor:default;position:relative;overflow:hidden}
  .stack-card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,#4f7fff06,transparent);opacity:0;transition:opacity .3s}
  .stack-card:hover{border-color:#4f7fff44;transform:translateY(-4px)}
  .stack-card:hover::before{opacity:1}
  .card-icon{font-size:28px;margin-bottom:20px;display:block}
  .card-title{font-size:17px;font-weight:600;color:var(--text);margin-bottom:8px}
  .card-desc{font-size:14px;color:var(--muted);line-height:1.6}
  .card-tags{display:flex;gap:8px;flex-wrap:wrap;margin-top:20px}
  .tag{font-family:var(--mono);font-size:11px;color:var(--accent);background:#4f7fff14;border:0.5px solid #4f7fff33;padding:4px 10px;border-radius:6px}

  .project-showcase{margin-top:64px;background:var(--surface);border:0.5px solid var(--border);border-radius:24px;overflow:hidden;display:grid;grid-template-columns:1fr 1fr;min-height:420px}
  @media(max-width:768px){.project-showcase{grid-template-columns:1fr}}
  .project-left{padding:52px 48px;display:flex;flex-direction:column;justify-content:center}
  .project-badge{display:inline-flex;align-items:center;gap:6px;font-family:var(--mono);font-size:11px;color:var(--green);background:#22c98a14;border:0.5px solid #22c98a33;padding:6px 12px;border-radius:100px;margin-bottom:24px}
  .project-title{font-size:36px;font-weight:700;letter-spacing:-1.5px;color:var(--text);margin-bottom:16px}
  .project-desc{font-size:15px;color:var(--muted);line-height:1.7;margin-bottom:32px}
  .project-stack{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:36px}
  .project-right{background:var(--surface2);border-left:0.5px solid var(--border);display:flex;align-items:center;justify-content:center;padding:40px}
	.phone-mockup-image{width: 60%; background:#1e1e2e;border-radius:30px;border:6px solid #2a2a3e;padding:20px 14px;box-shadow:0 32px 80px #00000066; display: flex; align-items: center; justify-content: center;}
	.phone-mockup-image img{border-radius: 8px;}
  .phone-mockup{width:160px;background:#1e1e2e;border-radius:30px;border:6px solid #2a2a3e;padding:20px 14px;box-shadow:0 32px 80px #00000066}
  .phone-screen{background:#12121a;border-radius:18px;padding:16px;min-height:280px}
  .app-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px}
  .app-icon{width:32px;height:32px;background:linear-gradient(135deg,var(--accent),var(--accent2));border-radius:8px}
  .app-title{font-size:11px;font-weight:600;color:var(--text)}
  .med-card{background:var(--surface);border-radius:12px;padding:12px;margin-bottom:10px;border:0.5px solid var(--border2)}
  .med-name{font-size:10px;font-weight:600;color:var(--text);margin-bottom:4px}
  .med-time{font-size:9px;color:var(--muted)}
  .med-dot{width:8px;height:8px;border-radius:50%;float:right;margin-top:2px}
  .dot-green{background:var(--green)}
  .dot-accent{background:var(--accent)}
  .progress-bar{height:4px;background:var(--border2);border-radius:100px;margin-top:20px;overflow:hidden}
  .progress-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2));width:68%;border-radius:100px}
  .progress-label{font-size:9px;color:var(--muted);margin-top:6px}

  .cta-section{position:relative;z-index:1;padding:100px 40px;max-width:1100px;margin:0 auto}
  .cta-inner{background:linear-gradient(135deg,var(--surface),var(--surface2));border:0.5px solid var(--border2);border-radius:28px;padding:80px 60px;text-align:center;position:relative;overflow:hidden}
  .cta-inner::before{content:'';position:absolute;width:300px;height:300px;background:radial-gradient(circle,#4f7fff18,transparent);top:-100px;right:-100px;border-radius:50%}
  .cta-title{font-size:clamp(32px,5vw,56px);font-weight:700;letter-spacing:-2px;margin-bottom:20px;color:var(--text)}
  .cta-sub{font-size:18px;color:var(--muted);margin-bottom:48px;max-width:500px;margin-left:auto;margin-right:auto;line-height:1.6}
  .email-link{display:inline-flex;align-items:center;gap:10px;background:var(--accent);color:#fff;font-size:16px;font-weight:600;padding:18px 40px;border-radius:14px;text-decoration:none;transition:all .2s;font-family:var(--font)}
  .email-link:hover{background:#3d6ee8;transform:translateY(-2px);box-shadow:0 12px 40px #4f7fff44}

  footer{z-index:1;position:relative;padding:40px;border-top:0.5px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px}
  .footer-logo{font-family:var(--mono);font-size:16px;font-weight:600;color:var(--muted);text-decoration:none}
  .footer-logo span{color:var(--accent)}
  .footer-copy{font-size:13px;color:var(--muted)}
</style>

<div class="noise"></div>
<div class="glow-orb orb1"></div>
<div class="glow-orb orb2"></div>

<nav>
  <!-- <a href="/" class="logo">Enx<span>od</span>3rz<span style="color:var(--green)">_</span></a>-->
  <div style="display: flex; align-items: center;">
    <img src="/enxod3rz_logo.png" alt="Enxod3rz Logo" style="height: 40px;">
  </div>
  <ul class="nav-links">
    <li><a href="#filosofia">Stack</a></li>
    <li><a href="#proyectos">Proyectos</a></li>
    <li><a href="#contacto">Contacto</a></li>
  </ul>
  <a href="mailto:enxod3rz@gmail.com" class="nav-cta">Hablemos →</a>
</nav>

<section class="hero">
