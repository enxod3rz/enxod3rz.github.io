      </div>
      <div style="font-size:13px;color:var(--muted)">Salud & Bienestar · Flutter</div>
    </div>
    <div class="project-right">
			<div class="phone-mockup-image">
				<img src="/capturaapp.png" alt="Captura de pantalla de la app LoTome">
